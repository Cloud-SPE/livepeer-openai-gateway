# Copy to .env and fill in the REQUIRED values. `docker compose up` reads this.
#
# Every variable here maps to a Zod-validated config loader under src/config/,
# or to a flag on the payment-daemon sidecar. See docs/operations/deployment.md
# for the full operator walkthrough.

# ----- Process ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8080
BRIDGE_AUTO_MIGRATE=true

# ----- service-registry-daemon (sidecar) -------------------------------------
# packages/bridge-core/src/config/serviceRegistry.ts. The daemon runs as a
# compose service alongside the bridge; bridge depends_on it.
SERVICE_REGISTRY_SOCKET=/var/run/livepeer/service-registry.sock
# SERVICE_REGISTRY_ADDRESS=host:port  # bridge -> daemon TCP override (takes precedence over socket)
# SERVICE_REGISTRY_HEALTH_INTERVAL_MS=10000
# SERVICE_REGISTRY_HEALTH_FAILURE_THRESHOLD=2
# SERVICE_REGISTRY_CALL_TIMEOUT_MS=5000

# Resolver contract used by the daemon's on-chain GetServiceURI() lookups.
# This repo defaults gateway deployments to the AI service registry. One
# resolver deployment targets exactly one registry contract.
# Arbitrum One AIServiceRegistry:
SERVICE_REGISTRY_CONTRACT_ADDRESS=0x04C0b249740175999E5BF5c9ac1dA92431EF34C5

# Override the daemon image pin (compose.yaml + compose.prod.yaml).
# SERVICE_REGISTRY_IMAGE=tztcloud/livepeer-service-registry-daemon:v3.0.2
# Filesystem path the compose stack mounts as /etc/livepeer/service-registry.yaml.
# Defaults to ./service-registry-config.yaml (gitignored, copied from
# service-registry-config.example.yaml).
# SERVICE_REGISTRY_CONFIG_PATH=./service-registry-config.yaml

# ----- Postgres --------------------------------------------------------------
# src/config/database.ts
PGHOST=postgres
PGPORT=5432
PGUSER=bridge
PGPASSWORD=bridge_dev_password
PGDATABASE=bridge
# PGPOOL_MAX=10
# PGSSL=false

# ----- Redis -----------------------------------------------------------------
# src/config/redis.ts
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ----- Auth ------------------------------------------------------------------
# src/config/auth.ts  (pepper must be >= 16 chars)
API_KEY_PEPPER=REQUIRED-CHANGE-ME-at-least-sixteen-chars-long-please
API_KEY_ENV_PREFIX=test
# AUTH_CACHE_TTL_MS=60000

# ----- PayerDaemon (bridge side) ---------------------------------------------
# src/config/payerDaemon.ts
PAYER_DAEMON_SOCKET=/var/run/livepeer/payment.sock
# PAYER_DAEMON_HEALTH_INTERVAL_MS=10000
# PAYER_DAEMON_HEALTH_FAILURE_THRESHOLD=2
# PAYER_DAEMON_CALL_TIMEOUT_MS=5000

# ETH address the payer-daemon's keystore signs for. The bridge sends
# this as the ?sender= query param when probing worker /quote and
# /quotes endpoints (introduced in 0018-worker-wire-format-alignment).
# Must match the address derived from the keystore mounted into the
# payment-daemon sidecar (see PAYER_KEYSTORE_PATH below). 0x-prefixed
# 40-hex.
BRIDGE_ETH_ADDRESS=REQUIRED-0x0000000000000000000000000000000000000000

# ----- Payment daemon sidecar (tztcloud/livepeer-payment-daemon:v3.0.2) -------------
# Chain RPC endpoint. Arbitrum One defaults baked into the daemon; only the
# RPC URL is operator-specific for the happy path.
CHAIN_RPC=REQUIRED-https://arb1.arbitrum.io/rpc-or-your-provider

# V3 JSON keystore + password file paths on the host. See the library docs
# (livepeer-payment-library/docs/operations/running-with-docker.md) for how to
# generate these with `geth account new`.
PAYER_KEYSTORE_PATH=./keystore.json
PAYER_KEYSTORE_PASSWORD_PATH=./keystore-password

# Optional: hot/cold wallet split. The mounted keystore signs transactions;
# PAYER_ORCH_ADDRESS is the cold orchestrator identity embedded in every ticket.
# To enable, set this AND uncomment `--orch-address` in compose.yaml.
# PAYER_ORCH_ADDRESS=0x...

# Optional: non-Arbitrum chain override. Set all four together AND uncomment
# the matching --expected-chain-id / --*-address flags in compose.yaml.
# EXPECTED_CHAIN_ID=1
# TICKETBROKER_ADDRESS=0x...
# ROUNDS_MANAGER_ADDRESS=0x...
# BONDING_MANAGER_ADDRESS=0x...

# ----- Stripe ----------------------------------------------------------------
# src/config/stripe.ts  (use test-mode keys for local dev)
STRIPE_SECRET_KEY=REQUIRED-sk_test_...
STRIPE_WEBHOOK_SECRET=REQUIRED-whsec_...
STRIPE_SUCCESS_URL=http://localhost:8080/success
STRIPE_CANCEL_URL=http://localhost:8080/cancel
# STRIPE_PRICE_MIN_CENTS=500
# STRIPE_PRICE_MAX_CENTS=50000

# ----- Admin -----------------------------------------------------------------
# src/config/admin.ts  (token must be >= 32 chars)
ADMIN_TOKEN=REQUIRED-CHANGE-ME-at-least-thirty-two-characters-long
# ADMIN_IP_ALLOWLIST=  # comma-separated, empty = allow any

# ----- Pricing ---------------------------------------------------------------
# src/config/pricing.ts  (optional overrides; defaults from design-doc)
# PRICING_DEFAULT_MAX_TOKENS_PREPAID=4096
# PRICING_DEFAULT_MAX_TOKENS_FREE=1024

# ----- Metrics (Prometheus) --------------------------------------------------
# src/config/metrics.ts. Empty / unset => /metrics is disabled, the bridge
# uses NoopRecorder, no listener is bound.
#
# Recommended port: :9602 (per
# `livepeer-modules-conventions/port-allocation.md`).
#
# IMPORTANT: bind 127.0.0.1 or an internal-LAN interface only — Prometheus
# exposition has no auth and must NOT face the public internet. Reverse-proxy
# scraper traffic over the cluster network. Examples:
#   METRICS_LISTEN=127.0.0.1:9602
#   METRICS_LISTEN=10.0.0.5:9602
# METRICS_LISTEN=

# Per-metric cardinality cap. Series past the cap are dropped silently and a
# warning is logged once per offending metric. 0 disables the cap.
# METRICS_MAX_SERIES_PER_METRIC=10000

# ----- Prod stack (compose.prod.yaml only) ----------------------------------
# Pinned image tag (defaults to v0.8.10 if unset).
# BRIDGE_IMAGE=tztcloud/livepeer-openai-gateway:v0.8.10

# Filesystem paths the prod compose mounts into the bridge container.
# Override on operator hosts where files don't sit alongside compose.yaml.
PAYER_KEYSTORE_PATH=./keystore.json
PAYER_KEYSTORE_PASSWORD_PATH=./keystore-password
DAEMON_LOG_LEVEL=info

# Public hostname for the customer-facing OpenAI endpoint. Traefik
# routes Host(${BRIDGE_PUBLIC_HOST}) to the bridge container; this is
# also what customers put in their OpenAI SDK base_url.
BRIDGE_PUBLIC_HOST=REQUIRED-openai.example.com

# Traefik knobs. Adjust if your Traefik uses different entrypoint /
# certresolver names.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
