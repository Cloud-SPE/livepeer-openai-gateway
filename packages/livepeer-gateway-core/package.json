{
  "name": "@cloudspe/livepeer-gateway-core",
  "version": "0.1.0-dev",
  "private": true,
  "description": "OSS engine: registry-driven node selection + payment-daemon orchestration + dispatchers + Fastify adapter for an OpenAI-compatible bridge over Livepeer WorkerNodes.",
  "license": "MIT",
  "homepage": "https://github.com/Cloud-SPE/livepeer-gateway-core",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cloud-SPE/livepeer-gateway-core.git"
  },
  "bugs": {
    "url": "https://github.com/Cloud-SPE/livepeer-gateway-core/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "migrations",
    "examples",
    "docs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "GOVERNANCE.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "fastify": "^4.29.0",
    "@fastify/multipart": "^8.3.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@grpc/grpc-js": "^1.14.3",
    "drizzle-orm": "^0.33.0",
    "eventsource-parser": "^3.0.8",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "tiktoken": "^1.0.22",
    "zod": "^3.25.76"
  }
}
