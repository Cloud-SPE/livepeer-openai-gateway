{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus instance scraping the openai-livepeer-bridge daemon",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operator-facing dashboard for the openai-livepeer-bridge. Top row joins bridge, daemon, and worker metrics to answer 'is the system honest' (cross-repo reconciliation). Subsequent rows mirror the bridge metric catalog in docs/design-docs/metrics.md.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Cross-repo reconciliation (is the system honest)",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 1,
      "title": "Gross margin %",
      "description": "Realized customer revenue (USD cents) minus node cost (wei converted via $eth_usd_cents) over revenue. Sustained < 20% means the rate-card under-prices the node pool.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 1, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "(sum(rate(livepeer_bridge_revenue_usd_cents_total{job=~\"$job\"}[5m])) - sum(rate(livepeer_bridge_node_cost_wei_total{job=~\"$job\"}[5m])) * $eth_usd_cents / 1e18) / clamp_min(sum(rate(livepeer_bridge_revenue_usd_cents_total{job=~\"$job\"}[5m])), 1e-9)",
          "legendFormat": "gross margin",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": -1,
          "max": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.2},
              {"color": "green", "value": 0.35}
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "thresholdsStyle": {"mode": "line"}
          }
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "min", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 2,
      "title": "Revenue cents/min by tier",
      "description": "Revenue rate per minute, split by customer tier. Mirrors the row 4 panel; here it sits alongside cost so margin shifts are diagnosable.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 1, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "sum by (tier) (rate(livepeer_bridge_revenue_usd_cents_total{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 3,
      "title": "Node cost wei/min",
      "description": "Total wei paid out per minute. Compare to revenue panel left for a visual margin read.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 18, "y": 1, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(livepeer_bridge_node_cost_wei_total{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "wei/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "type": "timeseries",
      "id": 4,
      "title": "Worker units served vs Bridge revenue (per capability/model)",
      "description": "Worker-side work_units rate vs bridge-side revenue rate for the same (capability, model). A persistent gap indicates tokenizer drift or a billing bug. Recording-rule note: a true 'units billed' figure requires dividing bridge revenue by the rate-card; until that recording rule exists, this panel shows revenue as a proxy. See README.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 9, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (capability, model) (rate(livepeer_worker_work_units_total[5m]))",
          "legendFormat": "worker units {{capability}}/{{model}}",
          "refId": "A"
        },
        {
          "expr": "sum by (capability, model) (rate(livepeer_bridge_revenue_usd_cents_total{job=~\"$job\"}[5m]))",
          "legendFormat": "bridge revenue cents {{capability}}/{{model}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Daemon-side gRPC p99 vs Bridge-side PayerDaemon p99 (CreatePayment)",
      "description": "Server-side p99 (livepeer_payment_*) vs client-side p99 (livepeer_bridge_payer_daemon_*) for CreatePayment, both measured from the fast histogram. The gap is unix-socket overhead. A persistent widening gap = socket pressure or kernel-side queueing.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 9, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(livepeer_payment_grpc_request_duration_seconds_fast_bucket{method=\"CreatePayment\"}[5m])))",
          "legendFormat": "p99 daemon (server)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(livepeer_bridge_payer_daemon_call_duration_seconds_fast_bucket{job=~\"$job\",method=\"CreatePayment\"}[5m])))",
          "legendFormat": "p99 bridge (client)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "p99 bridge (client)"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
          {"matcher": {"id": "byName", "options": "p99 daemon (server)"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },

    {
      "type": "row",
      "id": 200,
      "title": "Overview",
      "gridPos": {"x": 0, "y": 17, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "id": 6,
      "title": "Build version",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 18, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "livepeer_bridge_build_info{job=~\"$job\"}",
          "legendFormat": "{{version}} / {{node_env}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "name",
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue"}]}
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 7,
      "title": "Service up (build_info heartbeat)",
      "description": "build_info is a constant-1 gauge. Its presence is the 'service is up' signal — the bridge does not currently emit a setUptimeSeconds metric.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 4, "y": 18, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "max(livepeer_bridge_build_info{job=~\"$job\"})",
          "legendFormat": "up",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value_and_name",
        "graphMode": "none",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]},
          "mappings": [
            {"type": "value", "options": {"1": {"text": "UP", "color": "green"}}}
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 8,
      "title": "Request qps",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 8, "y": 18, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(livepeer_bridge_requests_total{job=~\"$job\"}[1m]))",
          "legendFormat": "qps",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue"}]}
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "id": 9,
      "title": "Customer-visible error rate (5m)",
      "description": "Share of requests with outcome 4xx/402/429/5xx. Green/yellow/red at 0/0.01/0.05 — set to your SLO.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 18, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(livepeer_bridge_requests_total{job=~\"$job\",outcome=~\"4xx|402|429|5xx\"}[5m])) / clamp_min(sum(rate(livepeer_bridge_requests_total{job=~\"$job\"}[5m])), 1e-9)",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 10,
      "title": "Healthy nodes",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 16, "y": 18, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "sum(livepeer_bridge_nodes_state{job=~\"$job\",state=\"healthy\"})",
          "legendFormat": "healthy",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 1}, {"color": "green", "value": 2}]}
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "id": 11,
      "title": "Oldest pending top-up age",
      "description": "Phase 2 placeholder — the bridge does not yet expose a `livepeer_bridge_topup_pending_oldest_seconds` gauge. When it lands, this panel becomes red ≥ 600s. Until then the panel reads 'No data', which is expected.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 20, "y": 18, "w": 4, "h": 4},
      "targets": [
        {
          "expr": "livepeer_bridge_topup_pending_oldest_seconds{job=~\"$job\"}",
          "legendFormat": "oldest pending",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 120}, {"color": "red", "value": 600}]}
        },
        "overrides": []
      }
    },

    {
      "type": "row",
      "id": 300,
      "title": "Customer requests",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 12,
      "title": "qps by capability + tier + outcome",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 23, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum by (capability, tier, outcome) (rate(livepeer_bridge_requests_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{capability}} / {{tier}} / {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}
        },
        "overrides": [
          {"matcher": {"id": "byRegexp", "options": ".*5xx.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]},
          {"matcher": {"id": "byRegexp", "options": ".*2xx.*"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 13,
      "title": "p99 latency by capability + tier",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 23, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, capability, tier) (rate(livepeer_bridge_request_duration_seconds_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p99 {{capability}} / {{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 14,
      "title": "Retries by attempt + reason",
      "description": "Stacked. High attempt=3 means retry policy is hiding pool-wide failures from customers — investigate node health.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 31, "w": 24, "h": 7},
      "targets": [
        {
          "expr": "sum by (reason, attempt) (rate(livepeer_bridge_node_retries_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{reason}} / attempt={{attempt}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "bars", "fillOpacity": 70, "stacking": {"mode": "normal"}}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}, "tooltip": {"mode": "multi"}}
    },

    {
      "type": "row",
      "id": 400,
      "title": "Money & ledger",
      "gridPos": {"x": 0, "y": 38, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 15,
      "title": "Revenue cents/min by tier",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 39, "w": 12, "h": 7},
      "targets": [
        {
          "expr": "sum by (tier) (rate(livepeer_bridge_revenue_usd_cents_total{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 16,
      "title": "Revenue cents/min by capability",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 39, "w": 12, "h": 7},
      "targets": [
        {
          "expr": "sum by (capability) (rate(livepeer_bridge_revenue_usd_cents_total{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "{{capability}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "stacking": {"mode": "normal"}}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "timeseries",
      "id": 17,
      "title": "Top-ups by outcome",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 0, "y": 46, "w": 12, "h": 7},
      "targets": [
        {
          "expr": "sum by (outcome) (rate(livepeer_bridge_topups_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "bars", "fillOpacity": 70, "stacking": {"mode": "normal"}}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "ok"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
          {"matcher": {"id": "byName", "options": "error"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"]}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "gauge",
      "id": 18,
      "title": "Open reservations",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 12, "y": 46, "w": 6, "h": 7},
      "targets": [
        {
          "expr": "max(livepeer_bridge_reservations_open{job=~\"$job\"})",
          "legendFormat": "open",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 50,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 10}]}
        },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "id": 19,
      "title": "Oldest open reservation age (LEDGER LEAK CANARY)",
      "description": "If this exceeds 5 minutes, a reservation is stuck mid-commit — investigate the ledger commit path. This is the headline canary for billing-side leaks.",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"x": 18, "y": 46, "w": 6, "h": 7},
      "targets": [
        {
          "expr": "max(livepeer_bridge_reservation_open_oldest_seconds{job=~\"$job\"})",
          "legendFormat": "oldest",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 1200,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 300}]}
        },
        "overrides": []
      }
    },

    {
      "type": "row",
      "id": 500,
      "title": "Stripe webhook",
      "gridPos": {"x": 0, "y": 53, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "id": 20,
