{
  "name": "livepeer-openai-gateway-monorepo",
  "version": "3.0.4",
  "private": true,
  "description": "Monorepo root for the livepeer-openai-gateway shell (built on @cloudspe/livepeer-openai-gateway-core) + frontend SPAs.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces && npm run build:ui",
    "build:ui": "cd frontend && npm ci && npm run build:all",
    "dev:ui:portal": "cd frontend && npm run dev:portal",
    "dev:ui:admin": "cd frontend && npm run dev:admin",
    "start": "npm --workspace=livepeer-openai-gateway run start",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspaces && npm run test:ui",
    "test:nocov": "npm --workspace=livepeer-openai-gateway run test:watch -- run",
    "test:ui": "cd frontend && npm ci && npx playwright install chromium && npm run test:all",
    "lint": "npm run lint --workspaces",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "doc-lint": "node ./lint/doc-gardener/index.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --experimental-strip-types ./packages/livepeer-openai-gateway/src/scripts/migrate.ts",
    "docker:build": "docker build -t livepeer-openai-gateway:local .",
    "docker:tag": "scripts/docker-tag.sh",
    "docker:push": "scripts/docker-push.sh",
    "docker:release": "npm run docker:build && npm run docker:tag && npm run docker:push"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^1.6.1",
    "drizzle-kit": "^0.24.2",
    "eslint": "^10.2.1",
    "js-yaml": "^4.1.1",
    "openai": "^4.104.0",
    "playwright": "^1.49.0",
    "prettier": "^3.8.3",
    "testcontainers": "^11.14.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^1.6.1"
  }
}
