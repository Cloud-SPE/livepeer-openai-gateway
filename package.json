{
  "name": "openai-livepeer-bridge",
  "version": "0.0.0",
  "private": true,
  "description": "OpenAI-compatible API service fronting Livepeer WorkerNodes",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:nocov": "vitest run",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "doc-lint": "node ./lint/doc-gardener/index.mjs",
    "proto:check": "npm run proto:gen && git diff --exit-code -- src/providers/payerDaemon/gen/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --experimental-strip-types ./src/scripts/migrate.ts",
    "proto:gen": "rm -rf src/providers/payerDaemon/gen && mkdir -p src/providers/payerDaemon/gen && buf generate"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.68.4",
    "@testcontainers/postgresql": "^10.28.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^1.6.1",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.39.4",
    "openai": "^4.104.0",
    "prettier": "^3.8.3",
    "testcontainers": "^10.28.0",
    "ts-proto": "^2.11.6",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/sensible": "^5.6.0",
    "@grpc/grpc-js": "^1.14.3",
    "drizzle-orm": "^0.33.0",
    "eventsource-parser": "^3.0.8",
    "fastify": "^4.29.1",
    "fastify-raw-body": "^4.3.0",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "stripe": "^17.7.0",
    "tiktoken": "^1.0.22",
    "zod": "^3.25.76"
  }
}
